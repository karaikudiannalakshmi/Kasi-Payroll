rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // For now — authenticated access only (add Firebase Auth later)
    // During setup, you can temporarily use: allow read, write: if true;

    match /employees/{empId} {
      allow read, write: if true;
    }
    match /attendance/{month}/employees/{empId} {
      allow read, write: if true;
    }
    match /holidays/{month} {
      allow read, write: if true;
    }
    match /advances/{advId} {
      allow read, write: if true;
    }
    match /loans/{loanId} {
      allow read, write: if true;
      match /payments/{month} {
        allow read, write: if true;
      }
    }
    match /salaries/{month}/employees/{empId} {
      allow read, write: if true;
    }
  }
}
